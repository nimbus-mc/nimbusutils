{
	"schemaVersion": 1,
	"id": "nimbusutils",
	"version": "${version}",
	"name": "NimbusUtils",
	"description": "Adds some useful features on playnimbus.net",
	"authors": [
		"synicalmx"
	],
	"contact": {
		"homepage": "https://playnimbus.net/",
		"sources": "https://github.com/nimbus-mc/NimbusUtils"
	},
	"license": "MIT",
	"icon": "assets/nimbusutils/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			"net.playnimbus.nimbusutils.NimbusUtils"
		],
		"client": [
          "net.playnimbus.nimbusutils.NimbusUtilsClient"
		],
		"modmenu": [
			"net.playnimbus.nimbusutils.ModMenuImplementation"
		]
	},
	"mixins": [
		"nimbusutils.mixins.json",
		{
			"config": "nimbusutils.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.18.2",
		"minecraft": "~26.1.2",
		"java": ">=25",
		"fabric-api": "*",
		"modmenu": ">=18.0.0-beta.1",
		"cloth-config": ">=26.1.154"
	}
}